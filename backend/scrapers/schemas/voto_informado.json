          "experiencia_politica": "Regidora de Lima Metropolitana 2019-2022",
          "antecedentes_penales": false,
          "antecedentes_detalle": null,
          "sentencias": false,
          "sentencias_detalle": null,
          "bienes_muebles": 45000.00,
          "bienes_inmuebles": 320000.00,
          "ingresos_anuales": 96000.00,
          "plan_de_gobierno_url": "https://votoinformado.jne.gob.pe/plan/fp-2026.pdf",
          "foto_url": "https://votoinformado.jne.gob.pe/fotos/45678901.jpg",
          "hoja_vida_url": "https://votoinformado.jne.gob.pe/hoja-vida/JNE-2026-001234"
        },

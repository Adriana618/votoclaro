          "ingresos_anuales": 180000.00,
          "plan_de_gobierno_url": "https://votoinformado.jne.gob.pe/plan/rp-2026.pdf",
          "foto_url": "https://votoinformado.jne.gob.pe/fotos/12345678.jpg",
          "hoja_vida_url": "https://votoinformado.jne.gob.pe/hoja-vida/JNE-2026-005678"
        },
        {
